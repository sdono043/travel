rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isFamilyMember() {
      return request.auth != null
        && request.auth.token.email != null
        && exists(/databases/$(database)/documents/familyMembers/$(request.auth.token.email.lower()));
    }

    // Membership docs are managed manually in the console / via the Firebase
    // CLI — clients can never list or write this collection. A signed-in
    // user may only read their OWN doc, to check their own allowlist status
    // during sign-in/sign-up (see isAllowedFamilyMember in js/auth.js).
    match /familyMembers/{email} {
      allow get: if request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email.lower() == email;
      allow list, write: if false;
    }

    match /trips/{tripId} {
      allow read, write: if isFamilyMember();

      match /bookings/{bookingId} {
        allow read, write: if isFamilyMember();
      }

      match /recommendations/{recId} {
        allow read, write: if isFamilyMember();
      }

      match /itinerary/{itemId} {
        allow read, write: if isFamilyMember();
      }
    }
  }
}
